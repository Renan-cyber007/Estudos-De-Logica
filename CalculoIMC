algoritmo "CalculoIMC"
var
   M,A,IMC:REAL
inicio
   escreva("massa(kg): ")
   leia(M)
   escreva("altura(m): ")
   leia(A)
   IMC <- M/ (A ^ 2)
   escreval("IMC: ", IMC:5:2)
   SE(IMC>=18.5) E (IMC<25) ENTAO
      escreva("Parabens Voce Esta No Seu Peso Ideal")
   senao
      escreva("Voce Nao Esta Na Faixa De Peso Ideal")
   FIMSE
fimalgoritmo
